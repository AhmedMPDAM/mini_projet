# =============================================================
# Environment Configuration - Leave Management System
# Copy this file to .env and fill in your values
# =============================================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/leave_management

# JWT Secrets – use long, random strings in production
# SECURITY: Never commit real secrets to version control
JWT_ACCESS_SECRET=your_access_token_secret_here_change_me
JWT_REFRESH_SECRET=your_refresh_token_secret_here_change_me

# Token expiration durations
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Server port
PORT=5000

# Frontend URL (for CORS and password-reset links)
CLIENT_URL=http://localhost:5173

# SMTP Configuration (for forgot-password emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
